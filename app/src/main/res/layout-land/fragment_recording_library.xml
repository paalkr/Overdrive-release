<?xml version="1.0" encoding="utf-8"?>
<!--
  Recording library — v4 redesign (landscape).

  Same structure as portrait but tighter vertical so the list keeps the most
  pixels in 540dp-tall landscape. Date jump and filter bar share a single row
  on landscape to claw back vertical space.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <!-- Combined header: date jump on the left, filter bar on the right. -->
    <LinearLayout
        android:id="@+id/dateRowContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:baselineAligned="false">

        <!-- Left: date jump (◀ card ▶) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrevDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_previous_day"
                app:icon="@drawable/ic_chevron_left"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDateJump"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardElevation="0dp"
                app:cardCornerRadius="@dimen/card_radius_accent"
                app:rippleColor="?attr/colorPrimary"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_events"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="Today" />

                    <TextView
                        android:id="@+id/tvDayClipCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/recording_lib_count_pill"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"
                        tools:text="12 clips"
                        tools:visibility="visible" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_next_day"
                app:icon="@drawable/ic_chevron_right"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>

        <!-- Right: filter bar — active chips + Filter pill -->
        <LinearLayout
            android:id="@+id/filterBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp">

            <HorizontalScrollView
                android:id="@+id/activeFiltersScroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/activeFiltersGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:singleLine="true" />
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenFilters"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/cd_open_filters"
                android:text="@string/recording_lib_filter_button"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:minHeight="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_filter_list"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:cornerRadius="18dp"
                app:strokeColor="?attr/colorOutline" />
        </LinearLayout>
    </LinearLayout>

    <!-- Recordings list + empty state + bottom action bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRecordings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp" />

        <!-- SOTA empty state mirrors the portrait layout. Tonal disc +
             icon + headline + body + (filter-aware) CTA. -->
        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="24dp">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/recording_lib_empty_disc">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_videocam_off"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/recording_lib_empty_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvEmptyStateBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="@string/recording_lib_empty_body"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEmptyClearFilters"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="14dp"
                android:text="@string/recording_lib_empty_clear_filters"
                android:textAllCaps="false"
                android:visibility="gone"
                app:cornerRadius="19dp"
                app:icon="@drawable/ic_clear"
                app:iconSize="18dp" />
        </LinearLayout>

        <!-- Multi-select bottom action bar (overlay; identical IDs to
             portrait so the Kotlin lookup is the same on both). -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/selectToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:cardCornerRadius="@dimen/card_radius_accent"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/recording_lib_selected_count_zero" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectAll"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/action_select_all_short"
                    android:textSize="12sp"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareSelected"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:contentDescription="@string/cd_share"
                    android:text="@string/action_share"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_share"
                    app:iconSize="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteSelected"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/action_delete"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/status_danger"
                    app:icon="@drawable/ic_delete"
                    app:iconTint="@color/status_danger"
                    app:iconSize="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelSelect"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/action_cancel"
                    app:icon="@drawable/ic_clear"
                    app:iconSize="18dp"
                    app:iconTint="?attr/colorOnSurfaceVariant"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</LinearLayout>
