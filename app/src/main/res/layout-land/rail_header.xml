<?xml version="1.0" encoding="utf-8"?>
<!--
  Rail header — landscape variant (compact). Brand logo intentionally
  removed (see layout/rail_header.xml comment).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <ImageButton
        android:id="@+id/railLanguageButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/settings_language_label"
        android:src="@drawable/ic_language"
        app:tint="?attr/colorOnSurfaceVariant" />

    <ImageButton
        android:id="@+id/railHelpButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/onboarding_help_cd"
        android:src="@drawable/ic_help"
        app:tint="?attr/colorOnSurfaceVariant" />
</LinearLayout>
