<?xml version="1.0" encoding="utf-8"?>
<!--
  Rail header.

  We deliberately do NOT show the brand mark here. The earlier camera-lens
  logo got rendered by the rail with `app:tint="?attr/colorPrimary"` which
  flattened the multi-color vector to a solid green disk — a "useless big
  green dot" that read as a status indicator rather than a brand. The
  shell's title sits in the toolbar; the rail header now only carries the
  language affordance.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <ImageButton
        android:id="@+id/railLanguageButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/settings_language_label"
        android:src="@drawable/ic_language"
        app:tint="?attr/colorOnSurfaceVariant" />

    <ImageButton
        android:id="@+id/railHelpButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/onboarding_help_cd"
        android:src="@drawable/ic_help"
        app:tint="?attr/colorOnSurfaceVariant" />
</LinearLayout>
