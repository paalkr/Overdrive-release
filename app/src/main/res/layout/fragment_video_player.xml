<?xml version="1.0" encoding="utf-8"?>
<!--
  SOTA Video player overlay.

  Composition: full-bleed ZoomableVideoView with two overlay bars (top +
  bottom) plus a floating quadrant selector pill above the bottom controls.
  Both overlays use semi-transparent black scrims rather than M3 surface
  tokens — this is INTENTIONAL.

  Why dark-only chrome (the only place in the app that doesn't follow
  ?attr/colorBackground):
    The player runs in front of arbitrary video frames. A light theme
    overlay would be unreadable over a bright sky shot or a sunlit road,
    and chrome legibility matters more than theme correctness here.
    Most pro players (YouTube, VLC, ExoPlayer's PlayerView, Photos) make
    the same call. The video surface itself is also #000000 by spec —
    that's the letterbox color, not a theme decision.

  Brand correctness:
    The progress / thumb tint is ?attr/colorPrimary (brand teal), so the
    accent still flips to the dark-mode primary when the rest of the app
    does. The previous build hard-coded #6C63FF (purple) which never
    matched anything in the design system — that has been replaced.

  Preserved IDs (VideoPlayerFragment.kt findViewById targets):
    videoView, btnBack, tvTitle, tvMeta, topBar, bottomControls,
    eventTimeline, seekBar, btnPlayPause, btnPrev, btnNext,
    tvCurrentTime, tvDuration, tvEventInfo

  Quadrant zoom (single-camera fullscreen over the AVM 2x2 mosaic):
    quadrantBar, btnQuadrantAll, btnQuadrantFront, btnQuadrantRight,
    btnQuadrantRear, btnQuadrantLeft. The video surface is a
    ZoomableVideoView so it can apply a TextureView matrix per
    quadrant — see VideoPlayerFragment.setQuadrant for the wiring.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video Surface — letterboxed black is by spec, not theme.
         ZoomableVideoView lets us apply a per-quadrant matrix transform so
         the user can see one of the four AVM cameras at native resolution
         without re-encoding. Same VideoView API surface (setVideoURI,
         start, pause, currentPosition, ...) so the fragment doesn't care. -->
    <com.overdrive.app.ui.view.ZoomableVideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- ==================== TOP BAR ==================== -->
    <!-- Dark scrim is intentional; see header comment. -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#99000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_back"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="middle"
            android:maxLines="1"
            android:text="@string/player_title_recording"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="#B3FFFFFF" />

        <!--
          Fullscreen toggle. Hidden by default; VideoPlayerFragment shows it
          only when the host registers an onFullscreenToggle callback (i.e.
          inline mode in the Recordings two-pane). Icon flips between
          ic_fullscreen and ic_fullscreen_exit to mirror current state.
        -->
        <!--
          Audio mute toggle. Visible whenever the player is loaded; the icon
          mirrors the current MediaPlayer mute state (set inside
          setupVideoPlayer's setOnPreparedListener).
        -->
        <ImageButton
            android:id="@+id/btnMute"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_player_mute"
            android:scaleType="centerInside"
            android:src="@drawable/ic_volume_off"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnFullscreen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_player_maximize"
            android:scaleType="centerInside"
            android:src="@drawable/ic_fullscreen"
            android:tint="#FFFFFF"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ==================== QUADRANT SELECTOR ====================
         Floats above the bottom controls so it stays out of the timeline
         while remaining within the auto-hide overlay group (the fragment
         fades it in/out together with topBar + bottomControls). The pill
         design follows M3 segmented-button visuals; selection state is
         driven from VideoPlayerFragment so the icon highlight stays in
         sync with the active ZoomableVideoView quadrant.

         clickable=true so taps in the pill's padding/margin gaps absorb
         here rather than falling through to the ZoomableVideoView's
         GestureDetector — without it, double-tapping a button gap would
         zoom into a quadrant of the video underneath the bar.

         No android:tint on the ImageButtons: the vector drawables encode
         their own lit/dim cell colors (ic_quadrant_*), and a tint would
         flatten all four cells to a single color, killing the position
         map. -->
    <LinearLayout
        android:id="@+id/quadrantBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="120dp"
        android:background="@drawable/bg_quadrant_bar"
        android:clickable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp">

        <ImageButton
            android:id="@+id/btnQuadrantAll"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_player_quadrant_all"
            android:scaleType="centerInside"
            android:src="@drawable/ic_quadrant_all" />

        <ImageButton
            android:id="@+id/btnQuadrantFront"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_player_quadrant_front"
            android:scaleType="centerInside"
            android:src="@drawable/ic_quadrant_front" />

        <ImageButton
            android:id="@+id/btnQuadrantRight"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_player_quadrant_right"
            android:scaleType="centerInside"
            android:src="@drawable/ic_quadrant_right" />

        <ImageButton
            android:id="@+id/btnQuadrantRear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_player_quadrant_rear"
            android:scaleType="centerInside"
            android:src="@drawable/ic_quadrant_rear" />

        <ImageButton
            android:id="@+id/btnQuadrantLeft"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_player_quadrant_left"
            android:scaleType="centerInside"
            android:src="@drawable/ic_quadrant_left" />
    </LinearLayout>

    <!-- ==================== BOTTOM CONTROLS ==================== -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <!-- Event Timeline -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical"
                android:background="#33FFFFFF" />

            <com.overdrive.app.ui.view.EventTimelineView
                android:id="@+id/eventTimeline"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- Seek bar — brand teal accent so it matches the rest of the app -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressBackgroundTint="#55FFFFFF"
            android:progressTint="?attr/colorPrimary"
            android:thumbTint="?attr/colorPrimary" />

        <!-- Time + transport row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_player_prev"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#FFFFFF"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_play_pause"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_pause"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_player_next"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_next"
                android:tint="#FFFFFF"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="monospace"
                android:text="@string/player_time_zero"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/player_time_separator"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="#80FFFFFF" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/player_time_zero"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvEventInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="#B3FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
